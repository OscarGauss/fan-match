generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Match {
  id          String      @id @default(cuid())
  name        String
  ownerWallet String
  roomId      String?     // legacy — kept for existing matches
  roomIdRed   String?
  roomIdBlue  String?
  status      MatchStatus @default(WAITING)
  startedAt   DateTime?   // wall-clock time when owner clicked Start
  scoreRed    Int         @default(0)
  scoreBlue   Int         @default(0)
  data        Json?       // generic JSON blob for future use
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum MatchStatus {
  WAITING
  ACTIVE
  FINISHED
}
