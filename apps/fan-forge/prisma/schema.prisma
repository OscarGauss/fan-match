generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Match {
  id          String      @id @default(cuid())
  name        String
  ownerWallet String
  roomId      String?
  status      MatchStatus @default(WAITING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum MatchStatus {
  WAITING
  ACTIVE
  FINISHED
}
