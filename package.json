{
  "name": "fan-match",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:chat-api": "npm run dev --workspace=apps/chat-api",
    "build:chat-api": "npm run build --workspace=apps/chat-api",
    "dev:fan-forge": "npm run dev --workspace=apps/fan-forge",
    "db:generate": "f() { npm run db:generate --workspace=apps/${1:-web}; }; f",
    "db:migrate": "f() { npm run db:migrate --workspace=apps/${1:-web}; }; f",
    "db:push": "f() { npm run db:push --workspace=apps/${1:-web}; }; f",
    "db:studio": "f() { npm run db:studio --workspace=apps/${1:-web}; }; f"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
